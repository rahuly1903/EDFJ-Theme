{% if product.tags contains "NY Rings" %}

  {% if section.settings.enable_payment_button %}
  {% if current_variant.available %}
  {{ form | payment_button }}
  {% endif %}
  {% endif %}

  <div class="product-form__error-message-wrapper product-form__error-message-wrapper--hidden{% if section.settings.enable_payment_button %} product-form__error-message-wrapper--has-payment-button{% endif %}" data-error-message-wrapper role="alert">
    <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
    {% include 'icon-error' %}
    <span class="product-form__error-message" data-error-message>{{ 'products.product.quantity_minimum_message' | t }}</span>
  </div>

  <div class="shopify-payment-button sticky" {% unless current_variant.available %}style="display:none;"{% endunless %}>
    <button type="button"
            class="shopify-payment-button__button shopify-payment-button__button--unbranded" 
            data-testid="Checkout-button">
      <span class="checkout-text">Buy now</span>
      <span class="hide" data-loader>
        {% include 'icon-spinner' %}
      </span>
    </button>
  </div>

  <div class="product_button">
    <div class="product_button-cart">
      <button class="btn add-to-cart-button" {% unless current_variant.available %}style="display:none;"{% endunless %} type="submit" name="add"                      
              aria-label="{{ 'products.product.add_to_cart' | t }}"
              {% if current_variant.available %}data-add-to-cart{% endif %}>
        <img class="lazyload" data-src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/Bag_Button_Icon_-_Big.png?v=1616499241" data-sizes="auto" />
        <span data-add-to-cart-text>
          {{ 'products.product.add_to_cart' | t }}
        </span>
        <span class="hide" data-loader>
          {% include 'icon-spinner' %}
        </span>
      </button>
      <div id='mhaRnProduct'></div>
      {% if collection_vault %}
      <button class="btn vault-sold-out" {% unless current_variant.available %}style="display:block;"{% endunless %} type="button">
        <img class="lazyload" data-src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/Bag_Button_Icon_-_Big.png?v=1616499241" data-sizes="auto" />
        <span>
          Sold out
        </span>
      </button>
      {% endif %}
    </div>
	{% comment %}
    <div class="product_button-video">
      {% include 'swym-product-view', product: product %}
      <button class="btn" type="button" data-sku="{{ current_variant.sku }}">Video Consultation</button>
    </div>
    {% endcomment %}
  </div>

{% else %}

  {% if section.settings.enable_payment_button %}
  {% if current_variant.available %}
  {{ form | payment_button }}
  {% endif %}
  {% endif %}

  <div class="product-form__error-message-wrapper product-form__error-message-wrapper--hidden{% if section.settings.enable_payment_button %} product-form__error-message-wrapper--has-payment-button{% endif %}" data-error-message-wrapper role="alert">
    <span class="visually-hidden">{{ 'general.accessibility.error' | t }} </span>
    {% include 'icon-error' %}
    <span class="product-form__error-message" data-error-message>{{ 'products.product.quantity_minimum_message' | t }}</span>
  </div>
  <div class="shopify-payment-button sticky" {% unless current_variant.available %}style="display:none;"{% endunless %}>
    <button type="button"
            class="shopify-payment-button__button shopify-payment-button__button--unbranded" 
            data-testid="Checkout-button">
      <span class="checkout-text">Buy now</span>
      <span class="hide" data-loader>
        {% include 'icon-spinner' %}
      </span>
    </button>
  </div>

  <div class="product_button">
    <div class="product_button-cart">
      <button class="btn add-to-cart-button" {% unless current_variant.available %}style="display:none;"{% endunless %} type="submit" name="add"                      
              aria-label="{{ 'products.product.add_to_cart' | t }}"
              {% if current_variant.available %}data-add-to-cart{% endif %}>
        <img class="lazyload" data-src="{{ 'Bag-blue.svg' | asset_url }}" data-sizes="auto" />
        <span data-add-to-cart-text>
          {{ 'products.product.add_to_cart' | t }}
        </span>
        <span class="hide" data-loader>
          {% include 'icon-spinner' %}
        </span>
      </button>
      <div id='mhaRnProduct'></div>
      {% if collection_vault %}
      <button class="btn vault-sold-out" {% unless current_variant.available %}style="display:block;"{% endunless %} type="button">
        <img class="lazyload" data-src="//cdn.shopify.com/s/files/1/0267/0523/1943/t/70/assets/Bag-blue.svg?v=16242431330005339556" data-sizes="auto" />
        <span>
          Sold out
        </span>
      </button>
      {% endif %}
    </div>
	{% comment %}
    <div class="product_button-video">
      {% include 'swym-product-view', product: product %}
      <button class="btn" type="button" data-sku="{{ current_variant.sku }}">Video Consultation</button>
    </div>
    {% endcomment %}
  </div>

{% endif %}
{% comment %}<!-- Css to hide "Join waitlist button on vault product" -->{% endcomment %}
{% if collection_vault %}
<style>
  #mhaRnProduct{
    display:none !important;
  }
  .vault-sold-out{
  	display:none;
  }
</style>
{% endif %}