{% if section.settings.enable_section %}
<section id="banner-{{ section.id }}" class="section-spacing">
  <div class="page-width page-width-pd-0">
    {%- assign max_height = 720 -%}
    {% if section.settings.max-width != blank %}
    {% assign maxwidth = section.settings.max-width %}
    {% endif %}
    
    <div class="text-over-image">
      {% assign banner_image_large = section.settings.banner_large | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
      <div class="image-wrapper absolute-image-wrapper small--hide" style="padding-top:{{ 1 | divided_by: section.settings.banner_large.aspect_ratio | times: 100 }}%;">
        <img class="lazyload" 
             data-src="{{ banner_image_large }}" 
             data-widths="[180, 360, 375, 414, 540, 800, 1024, 1280, 1340, 1920 ]" 
             data-aspectratio="{{ section.settings.banner_large.aspect_ratio }}" 
             data-sizes="auto"
             alt="" />
      </div>
      {% assign banner_image_small = section.settings.banner_small | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
      <div class="image-wrapper absolute-image-wrapper medium-up--hide" style="padding-top:{{ 1 | divided_by: section.settings.banner_small.aspect_ratio | times: 100 }}%;">
        <img class="lazyload" 
             data-src="{{ banner_image_small }}" 
             data-widths="[180, 360, 375, 414, 540, 800, 1024, 1280, 1340, 1920 ]" 
             data-aspectratio="{{ section.settings.banner_small.aspect_ratio }}" 
             data-sizes="auto"
             alt="" />
      </div>

      <div class="banner-text{% if section.settings.horizontal_alignment == 'left' %} content_left-aligned{% endif %}{% if section.settings.horizontal_alignment == 'center' %} content_center-aligned{% endif %}{% if section.settings.horizontal_alignment == 'right' %} content_right-aligned{% endif %}">
        <div class="small--text-center banner-text-container{% if section.settings.text_align == 'center' %} text-center{% endif %}{% if section.settings.text_align == 'right' %} text-right{% endif %}">
          {% unless section.settings.subtitle == blank %}
          <span class="subtitle">{{ section.settings.subtitle }}</span>
          {% endunless %}
          {% unless section.settings.title == blank %}
          <h2 class="title">{{ section.settings.title }}</h2>
          {% endunless %}
          {% unless section.settings.text == blank %}
          <div class="text">{{ section.settings.text }}</div>
          {% endunless %}
          {% if section.settings.button_label and section.settings.button_url != blank %}
          <a class="btn-border btn-border-white" href="{{ section.settings.button_url }}">
            {% include 'btn-border' %}
            <span>{{ section.settings.button_label }}</span>
          </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>
{% endif %}

<style>
  .text-over-image-section .banner-text .title, 
  .text-over-image-section .banner-text .subtitle, 
  .text-over-image-section .banner-text .text p {color: {{ section.settings.color }};}
  {% if maxwidth != blank %}
  @media(max-width:1023px) and (min-width:750px){
    .text-over-image-section .text-over-image .banner-text-container {
      max-width: 442px;
    }
  }
  @media(min-width:1024px){
    .text-over-image-section .text-over-image .banner-text-container{
      max-width:{{ maxwidth }}px;
    }
  }
  {% endif %}
</style>

{% schema %}
{
  "name": "Text over image",
  "class": "text-over-image-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_section",
      "label": "Enable section",
	  "default": true
    },
    {
      "type": "image_picker",
      "id": "banner_large",
      "label": "Banner Image (Desktop)",
      "info": "Recommended size 1280x566 (px)"
    },
    {
      "type": "image_picker",
      "id": "banner_small",
      "label": "Banner Image (Mobile)",
      "info": "Recommended size 414x1450 (px)"
    },
    {
      "type": "select",
      "id": "horizontal_alignment",
      "label": "Content Alignment (Horizontal)",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text Align",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "color",
      "label": "Color"
    },
    {
      "type": "text",
      "id": "max-width",
      "label": "Text max width"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Title"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Subtitle"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
	  "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing, elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua Ut enim ad minim</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "category": "Image",
      "name": "Text over image"
    }
  ]
}
{% endschema %}