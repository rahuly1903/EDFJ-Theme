<div class="page-width">
  <section class="section-padding-top">
    <div class="grid">
      <div class="grid__item medium-up--one-half grid-content">
        <div class="section-title small--hide">
          {% if section.settings.sub_title != blank %}
          <span class="sub-title">{{ section.settings.sub_title }}</span>
          {% endif %}
          {% if section.settings.title != blank %}
          <h2 class="align-left">
            {{ section.settings.title }}
            <svg xmlns="http://www.w3.org/2000/svg" width="33.168" height="33.398" viewBox="0 0 33.168 33.398"><defs><style>.rewards-sparkle-a{fill:#11214a;}</style></defs><g transform="matrix(-0.906, -0.423, 0.423, -0.906, 28.541, 33.399)"><g transform="translate(0 0)"><path class="rewards-sparkle-a" d="M10.947,5.475a5.474,5.474,0,0,0-5.474,5.473A5.473,5.473,0,0,0,0,5.474,5.473,5.473,0,0,0,5.473,0,5.475,5.475,0,0,0,10.947,5.475Z" transform="translate(0 0)"/></g><g transform="translate(11.432 11.562)"><path class="rewards-sparkle-a" d="M13.611,6.805a6.806,6.806,0,0,0-6.806,6.806A6.8,6.8,0,0,0,0,6.805,6.8,6.8,0,0,0,6.805,0,6.805,6.805,0,0,0,13.611,6.805Z" transform="translate(0 0)"/></g><g transform="translate(28.538 7.525)"><path class="rewards-sparkle-a" d="M6.463,3.232A3.233,3.233,0,0,0,3.231,6.465,3.232,3.232,0,0,0,0,3.232,3.231,3.231,0,0,0,3.231,0,3.233,3.233,0,0,0,6.463,3.232Z" transform="translate(0 0)"/></g></g></svg>
          </h2>
          {% endif %}
        </div>
        <div class="text">
          <p>Refer a friend and add to your Sparkle bank when your friend makes their first purchase!</p>
          <p>Your friend gets <b>Flat 10%</b> Off & You get <b>200 Sparkles</b></p>
        </div>
        <div class="email-section">
          <input type="email" class="rewards-input" placeholder="Enter email id">
          <button class="rewards-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="31" height="31" viewBox="0 0 31 31"><defs><style>.rb-btn-arr-da,.rb-btn-arr-db{fill:#11214a;}.rb-btn-arr-da{opacity:0;}</style></defs><g transform="translate(-601 -445)"><rect class="rb-btn-arr-da" width="31" height="31" transform="translate(601 445)"/><g transform="translate(602.776 446.776)"><path class="rb-btn-arr-db" d="M22.528-57.482A13.882,13.882,0,0,0,36.317-71.27a13.9,13.9,0,0,0-13.8-13.788A13.888,13.888,0,0,0,8.74-71.27,13.89,13.89,0,0,0,22.528-57.482Zm0-2.3A11.435,11.435,0,0,1,11.052-71.27a11.432,11.432,0,0,1,11.463-11.49,11.475,11.475,0,0,1,11.5,11.49A11.438,11.438,0,0,1,22.528-59.78Zm6.975-11.5a1.072,1.072,0,0,0-.392-.784l-4.569-4.583a.969.969,0,0,0-.7-.27.953.953,0,0,0-.973.973,1,1,0,0,0,.3.716l1.7,1.676,1.622,1.365L23.637-72.3H16.581a.977.977,0,0,0-1,1.014.977.977,0,0,0,1,1.014h7.056l2.866-.108L24.867-69l-1.7,1.663a1,1,0,0,0-.3.73.972.972,0,0,0,.973.987.979.979,0,0,0,.7-.284l4.569-4.583A1.08,1.08,0,0,0,29.5-71.284Z" transform="translate(-8.74 85.059)"/></g></g></svg>
          </button>
        </div>
      </div>
      <div class="grid__item medium-up--one-half grid-image">
        <div class="section-title medium-up--hide">
          {% if section.settings.sub_title != blank %}
          <span class="sub-title">{{ section.settings.sub_title }}</span>
          {% endif %}
          {% if section.settings.title != blank %}
          <h2 class="align-left">
            {{ section.settings.title }}
            <svg xmlns="http://www.w3.org/2000/svg" width="33.168" height="33.398" viewBox="0 0 33.168 33.398"><defs><style>.rewards-sparkle-a{fill:#11214a;}</style></defs><g transform="matrix(-0.906, -0.423, 0.423, -0.906, 28.541, 33.399)"><g transform="translate(0 0)"><path class="rewards-sparkle-a" d="M10.947,5.475a5.474,5.474,0,0,0-5.474,5.473A5.473,5.473,0,0,0,0,5.474,5.473,5.473,0,0,0,5.473,0,5.475,5.475,0,0,0,10.947,5.475Z" transform="translate(0 0)"/></g><g transform="translate(11.432 11.562)"><path class="rewards-sparkle-a" d="M13.611,6.805a6.806,6.806,0,0,0-6.806,6.806A6.8,6.8,0,0,0,0,6.805,6.8,6.8,0,0,0,6.805,0,6.805,6.805,0,0,0,13.611,6.805Z" transform="translate(0 0)"/></g><g transform="translate(28.538 7.525)"><path class="rewards-sparkle-a" d="M6.463,3.232A3.233,3.233,0,0,0,3.231,6.465,3.232,3.232,0,0,0,0,3.232,3.231,3.231,0,0,0,3.231,0,3.233,3.233,0,0,0,6.463,3.232Z" transform="translate(0 0)"/></g></g></svg>
          </h2>
          {% endif %}
        </div>
        <div class="image_wrapper">
          <img class="lazyload" 
               src="{{ section.settings.banner | img_url: 'master' }}" 
               data-src="{{ section.settings.banner | img_url: 'master' }}" 
               data-sizes="auto" 
               alt="">
        </div>
      </div>
    </div>
  </section>
</div>

{% schema %}
  {
    "name": "Refer a friend",
	"class": "rewards-refer-friend",
    "settings": [
	  {
        "type": "text",
        "id": "title",
        "label": "Title",			
        "default": "Friend"
      },
      {
        "type": "text",
        "id": "sub_title",
        "label": "Sub title",			
        "default": "Refer a"
      },
	  {
        "type": "image_picker",
        "id": "banner",
        "label": "Banner",			
        "info": "Recommended size: 540px * 432px"
      }
	]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

