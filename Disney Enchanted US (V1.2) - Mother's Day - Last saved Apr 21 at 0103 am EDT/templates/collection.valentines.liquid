{% comment %}
The contents of the collection.liquid template can be found in /sections/collection-template.liquid
{% section 'collection-template' %}
{% endcomment %}

{% section 'mm-collection-template-valentines' %}

<style>
  .main-content {
    background: url('https://cdn.shopify.com/s/files/1/0267/0523/1943/files/2021_Belle_30th_FRONT.jpg?v=1620379403');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
  }
  .breadcrumb-container{
    display:none;
  }
  .mm-valentine-card{
    margin-bottom: 1rem;
  }
  .mm-valentine-card img{
    border-radius: 4px;
  }
  .mm-collection .product-container .mm-product-card .mm-product-image {
    padding: 4px 0 0 0;
    height: 290px;
  }
  .mm-collection .mm-filter .filter-option-heading h4 .toggle-icon:after, .mm-collection .mm-filter .filter-option-heading-lone h4 .toggle-icon:after, .mm-collection .mm-filter .filter-option-heading-ltwo h4 .toggle-icon:after,
  .mm-collection .mm-filter .filter-option-heading h4 .toggle-icon:before, .mm-collection .mm-filter .filter-option-heading-lone h4 .toggle-icon:before, .mm-collection .mm-filter .filter-option-heading-ltwo h4 .toggle-icon:before {
