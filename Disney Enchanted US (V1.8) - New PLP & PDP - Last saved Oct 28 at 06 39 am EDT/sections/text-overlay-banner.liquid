{% if section.settings.show_section %}
<div class="section-spacing">
  <div class="page-width">
    <div class="banner-wrapper">
      {% assign image_desk = section.settings.image_desk | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
      <div class="image-wrapper absolute-image-wrapper small--hide" style="padding-top:{{ 1 | divided_by: section.settings.image_desk.aspect_ratio | times: 100 }}%;">
        <img class="lazyload" 
             data-src="{{ image_desk }}" 
             data-widths="[180, 360, 375, 414, 540, 800, 1024, 1280, 1340, 1920 ]" 
             data-aspectratio="{{ section.settings.image_desk.aspect_ratio }}" 
             data-sizes="auto"
             alt="" />
      </div>
      {% assign image_mob = section.settings.image_mob | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
      <div class="image-wrapper absolute-image-wrapper medium-up--hide" style="padding-top:{{ 1 | divided_by: section.settings.image_mob.aspect_ratio | times: 100 }}%;">
        <img class="lazyload" 
             data-src="{{ image_mob }}" 
             data-widths="[180, 360, 375, 414, 540, 800, 1024, 1280, 1340, 1920 ]" 
             data-aspectratio="{{ section.settings.image_mob.aspect_ratio }}" 
             data-sizes="auto"
             alt="" />
      </div>
      <div class="banner-text small--text-center">
        <div class="content">
          {% if section.settings.title != blank %}
          <h2>{{ section.settings.title }}</h2>
          {% endif %}
          {% if section.settings.text != blank %}
          <p>{{ section.settings.text }}</p>
          {% endif %}
          {% if section.settings.button_label and section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="btn-border btn-white">
            <span class="btn-sparkle">{% include 'icon-sparkle' %}</span>
            {{ section.settings.button_label }}
            <span class="btn-sparkle">{% include 'icon-sparkle' %}</span>
          </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
{% endif %}

{% schema %}
  {
    "name": "Text overlay banner",
	"class": "text-overlay-banner",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_section",
        "label": "Show section",
        "default": true
      },
      {
        "type": "image_picker",
        "id": "image_desk",
        "label": "Image (Desktop)",
        "info": "Recommended size: 640px * 420px"
      },
      {
        "type": "image_picker",
        "id": "image_mob",
        "label": "Image (Mobile)",
        "info": "Recommended size: 414px * 420px"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Title"
      },
      {
        "type": "text",
        "id": "text",
        "label": "Text",
        "default": "Text"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Shop collection"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      }
    ],
	"presets": [
	  {
		"name": "Text overlay banner",
		"category": "Image"
	  }
	]
  }
{% endschema %}