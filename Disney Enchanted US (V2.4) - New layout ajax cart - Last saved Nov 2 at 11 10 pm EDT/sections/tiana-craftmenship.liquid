<section class="princess-craftmenship-section page-width">
  {% assign main_bg = section.settings.main_bg | img_url: 'master' %}
  {% assign main_bg_mob = section.settings.main_bg_mob | img_url: 'master' %}
  <div class="craftmenship-text">
    <img class="lazyload small--hide" data-src="{{ main_bg }}" data-sizes="auto">
    <img class="lazyload medium-up--hide" data-src="{{ main_bg_mob }}" data-sizes="auto">
    <div class="text section">
      {% if section.settings.section_title != blank %}
      <div class="heading_title">
        <h3>{{ section.settings.section_title }}</h3>
      </div>
      {% endif %}
      {% if section.settings.text != blank %}
      <div class="sub_heading">{{ section.settings.text }}</div>
      {% endif %}
    </div>
    {% assign top-left-image = section.settings.top-left-image | img_url: 'master' %}
    {% assign top-right-image = section.settings.top-right-image | img_url: 'master' %}
    {% assign bottom-left-image = section.settings.bottom-left-image | img_url: 'master' %}
    {% assign bottom-right-image = section.settings.bottom-right-image | img_url: 'master' %}
    {% if section.settings.top-left-image != blank %}
    <div class="top-left-image">
      <img class="lazyload" data-src="{{ top-left-image }}" data-sizes="auto">
    </div>
    {% endif %}
    {% if section.settings.top-right-image != blank %}
    <div class="top-right-image">
      <img class="lazyload" data-src="{{ top-right-image }}" data-sizes="auto">
    </div>
    {% endif %}
    {% if section.settings.bottom-left-image != blank %}
    <div class="bottom-left-image">
      <img class="lazyload" data-src="{{ bottom-left-image }}" data-sizes="auto">
    </div>
    {% endif %}
    {% if section.settings.bottom-right-image != blank %}
    <div class="bottom-right-image">
      <img class="lazyload " data-src="{{ bottom-right-image }}" data-sizes="auto">
    </div>
    {% endif %}
  </div>
</section>


{% schema %}
{
  "name": "Craftmenship Section",
  "class": "princess-craftmenship",
  "settings": [
  {
    "type": "image_picker",
    "id": "main_bg",
    "label": "Background Image"
  },
  {
    "type": "image_picker",
    "id": "main_bg_mob",
    "label": "Background Image Mob"
  },
  {
    "type": "text",
    "id": "section_title",
    "label": "Heading Text",
    "default": "Exquisite Design & Craftmenship"
  },
  {
    "type": "richtext",
    "id": "text",
    "label": "Sub Text",
    "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Vivamus quis nulla nunc. Etiam fringilla odio non sagittis dapibus. Quisque id enim dictum, egestas odio quis, tincidunt ipsum.</p> <p>Cras massa ante, consequat quis sapien a, porta tempus mi. Nulla fermentum euismod elementum. Phasellus lorem ligula, aliquam vel porta vel, placerat ac nibh.</p>"
  },
  {
    "type": "image_picker",
    "id": "top-left-image",
    "label": "Top Left Image"
  },
  {
    "type": "image_picker",
    "id": "top-right-image",
    "label": "Top right Image"
  },
  {
    "type": "image_picker",
    "id": "bottom-left-image",
    "label": "Bottom Left Image"
  },
  {
    "type": "image_picker",
    "id": "bottom-right-image",
    "label": "Bottom Right Image"
  }
  ]
}
{% endschema %}
