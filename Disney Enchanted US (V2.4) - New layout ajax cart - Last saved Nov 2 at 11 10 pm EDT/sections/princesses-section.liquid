<section class="section-wrapper" id="section-{{ section.id }}">
  <div class="page-width">
    <div class="custom-tabs-wrapper small--text-center">
      <div class="grid grid--no-gutters tabs">
        <div class="grid__item grid__item-tabs-content">
          <div class="tabs-content-wrapper">
            <h2 class="small--hide"><i>Princesses <br>&amp; more</i></h2>
            {% for block in section.blocks %}
            {% assign blockId = block.id %}
            {% assign desktopBanner = block.settings.dt_image %}
            {% assign mobileBanner = block.settings.mb_image %}
            {% assign bannerTitle = block.settings.title %}
            {% assign bannerTitleColor = block.settings.title_color %}
            {% assign bannerSubtitle = block.settings.sub_title %}
            {% assign bannerSubtitleColor = block.settings.subtitle_color %}
            {% assign bannerRichtext = block.settings.text %}
            {% assign bannerRichtextColor = block.settings.richtext_color %}
            {% assign bannerTitle2 = block.settings.title2 %}
            {% assign bannerTitleColor2 = block.settings.title2_color %}
            {% assign bannerButton = block.settings.button_label %}
            {% assign bannerButtonColor = block.settings.button_color %}
            {% assign bannerButtonHoverColor = block.settings.button_hover_color %}
            {% assign collection = block.settings.collection %}
            {% render 'tab-content', 
            	blockId:blockId,
            	loop_index:forloop.index,
            	desktopBanner:desktopBanner,
            	mobileBanner:mobileBanner,
            	bannerTitle:bannerTitle,
            	bannerTitleColor:bannerTitleColor,
            	bannerSubtitle:bannerSubtitle,
            	bannerSubtitleColor:bannerSubtitleColor, 
            	bannerRichtext:bannerRichtext,
            	bannerRichtextColor:bannerRichtextColor,
            	bannerTitle2:bannerTitle2,
            	bannerTitleColor2:bannerTitleColor2
            	bannerButton:bannerButton
            	bannerButtonColor:bannerButtonColor
            	bannerButtonHoverColor:bannerButtonHoverColor
            	collection:collection %}
            {% endfor %}
          </div>
        </div>
        <div class="grid__item grid__item-tabs">
          <div class="tabs-nav-wrapper">
            <ul class="tabs-nav">
              {% for block in section.blocks %}
              {% assign pp_title = block.settings.pp_title %}
              {% assign bannerTitle = block.settings.title %}
              {% render 'tab-nav',
          		loop_index:forloop.index,
              	bannerTitle:bannerTitle,
                pp_title:pp_title %}
              {% endfor %}
            </ul>
          </div>
        </div>
        <div class="grid__item grid__item-tabs-content">
          <div class="tabs-content-wrapper">
            {% for block in section.blocks %}
            {% assign collection_title = block.settings.collection_title %}
            {% assign collection = block.settings.collection %}
            {% assign grid = block.settings.grid %}
            {% assign show_button = block.settings.show_button %}
            {% include 'tab-slider', 
          	loop_index:forloop.index,
            collection_title:collection_title,
            collection:collection,
            grid:grid,
            show_button:show_button %}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Custom Tabs (Princesses)",
	"class": "custom-tabs-section princesses",
    "settings": [
      {
        "type": "header",
        "content": "Header"
      },
	  {
		"type": "text",
		"id": "title",
		"label": "Title",
		"default": "Title"
	  },
	  {
		"type": "text",
		"id": "sub_title",
		"label": "Subtitle",
		"default": "Subtitle"
	  }
	],
	"blocks": [
      {
      	"type": "block",
		"name": "Block",
		"settings": [
		  {
            "type": "header",
            "content": "Tab title"
          },
		  {
            "type": "text",
            "id": "pp_title",
            "label": "Princesses Title"
          },
		  {
            "type": "header",
            "content": "Banner section"
          },
          {
            "type": "image_picker",
            "id": "dt_image",
            "label": "Princesses Desktop banner "
          },
		  {
            "type": "image_picker",
            "id": "mb_image",
            "label": "Princesses Mobile banner "
          },
		  {
            "type": "text",
            "id": "sub_title",
            "label": "Subtitle",
			"default": "Subtitle"
          },
		  {
            "type": "color",
            "id": "subtitle_color",
            "label": "Subtitle color"
          },
		  {
            "type": "text",
            "id": "title",
            "label": "Title",
			"default": "Title"
          },
		  {
            "type": "color",
            "id": "title_color",
            "label": "Title color"
          },
		  {
            "type": "richtext",
            "id": "text",
            "label": "Text",
			"default": "<p>Add text to give information about your chosen collection.</p>"
          },
		  {
            "type": "color",
            "id": "richtext_color",
            "label": "Richtext color"
          },
		  {
            "type": "text",
            "id": "title2",
            "label": "Title 2",
			"default": "Title 2"
          },
		  {
            "type": "color",
            "id": "title2_color",
            "label": "Title2 color"
          },
		  {
            "type": "text",
            "id": "button_label",
            "label": "Button label",
			"default": "Shop collection"
          },
          {
            "type": "select",
            "id": "button_color",
            "label": "Button color",
            "default": "blue",
            "options": [
              {
                "value": "blue",
                "label": "Blue"
              },
              {
                "value": "gold",
                "label": "Gold"
              },
              {
                "value": "white",
                "label": "White"
              }
            ]
          },
          {
            "type": "select",
            "id": "button_hover_color",
            "label": "Button hover color",
            "default": "gold",
            "options": [
              {
                "value": "gold",
                "label": "Gold"
              },
              {
                "value": "blue",
                "label": "Blue"
              },
              {
                "value": "white",
                "label": "White"
              }
            ]
          },
		  {
            "type": "header",
            "content": "Slider section"
          },
		  {
            "type": "text",
            "id": "collection_title",
            "label": "Collection Title"
          },
          {
            "type": "collection",
            "id": "collection",
            "label": "Collection"
          },
		  {
            "type": "select",
            "id": "grid",
            "label": "Number of product grid",
            "options": [
              {
                "value": "3",
                "label": "3"
              },
              {
                "value": "4",
                "label": "4"
              },
              {
                "value": "5",
                "label": "5"
              }
            ],
            "default": "3"
          },
          {
            "type": "checkbox",
            "id": "show_button",
            "label": "Show view all button"
          }
		]
      }
	],
    "presets": [
      {
        "name": "Custom tabs (Princesses)",
        "category": "Advanced layout"
      }
    ]
  }
{% endschema %}

