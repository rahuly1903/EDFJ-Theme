{% unless template == 'index' %}
<nav class="breadcrumb" role="navigation" aria-label="breadcrumbs">
    <a href="/">Home</a>
    {% if template contains "product" %}
  
        {% if collection %}
        <span aria-hidden="true">&rsaquo;</span>
        {% if collection.handle %}
          {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
          {{ collection.title | link_to: url }}
        {% endif %}
      {% endif %}
        <span class="separator">&bull;</span>
        <span class="page-title">{{ product.title }}</span>
  
  	{% elsif template == "collection" %}
  
  		{% if collection.handle == 'engagement-rings' %}
		<span class="separator">&bull;</span> 
        <a href="/pages/bridal">Bridal</a>
  		{% endif %}
  
    {% elsif template == "article" %}
  
      <span class="separator">&bull;</span> 
      {{ blog.title | link_to: blog.url }}
  
  	{% elsif template contains "page" %}
  
  		{% assign pagename = page.handle %}
  			
  		{% if pagename == 'anna' or pagename == 'ariel' or pagename == 'aurora' or pagename == 'belle' or pagename == 'cinderella' or pagename == 'jasmine' or pagename == 'merida' or pagename == 'mulan' or pagename == 'pocahontas' or pagename == 'rapunzel' or pagename == 'snow-white' or pagename == 'tiana' or pagename == 'majestic-princess' or pagename == 'elsa' or pagename == 'tinkerbell' %}
        <span class="separator">&bull;</span>
        <a href="/pages/inspirations">Inspirations</a>
  		{% endif %}
  
  
    {% endif %}
    {% if template contains "product" %}
  	
  {% else %}
  	<span class="separator">&bull;</span>
    <span class="page-title">{{ page_title }}</span>
  {% endif %}
</nav>
{% endunless %}