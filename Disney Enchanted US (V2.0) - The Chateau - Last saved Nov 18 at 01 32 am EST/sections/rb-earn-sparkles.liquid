</div>
{% schema %}
  {
    "name": "Earn sparkles",
	"class": "rewards-earn-sparkles",
    "settings": [
	  {
        "type": "text",
        "id": "title",
        "label": "Title",			
        "default": "Sparkles"
      },
      {
        "type": "text",
        "id": "sub_title",
        "label": "Sub title",			
        "default": "Ways to earn"
      }
	]
  }
{% endschema %}

