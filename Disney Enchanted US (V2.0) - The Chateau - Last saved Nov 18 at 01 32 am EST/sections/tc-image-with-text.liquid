{% if section.settings.enable_section %}
<section class="sparkles-elements-wrapper section-spacing">
  <div class="sparkle-element left">
    <img src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/sparkle-element-left.svg?v=1631614083" alt="" />
  </div>
  <div class="page-width">
    {% assign image = section.settings.image | img_url: 'master' %}
    <div class="image-wrapper">
      <img class="lazyload"
           src="{{ image }}"
           data-src="{{ image }}"
           data-sizes="auto"
           alt="" />
    </div>
    <div class="section-content text-center">
      {% if section.settings.title != blank %}
      <h2 class="section-title">{{ section.settings.title }}</h2>
      {% endif %}
      {% if section.settings.sub_title != blank %}
      <span class="section-subtitle">{{ section.settings.sub_title }}</span>
      {% endif %}
      {% if section.settings.text != blank %}
      <div class="text">{{ section.settings.text }}</div>
      {% endif %}
    </div>
  </div>
  <div class="sparkle-element right">
    <img src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/sparkle-element-right.svg?v=1631614568" alt="" />
  </div>
</section>
{% endif %}

<style>
  @media screen and (min-width: 750px) {
    {% if section.settings.max-width != blank %}
    .tc-image-with-text .section-content {max-width: {{ section.settings.max-width }}px;}
    {% endif %}
  }
</style>

{% schema %}
  {
    "name": "Image with text",
	"class": "tc-image-with-text",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_section",
        "label": "Enable section",
        "default": true
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Image",
        "info": "Recommended size 1038x711 (px)"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Title"
      },
      {
        "type": "text",
        "id": "sub_title",
        "label": "Sub Title",
        "default": "Subtitle"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>Lorem ipsum dolor sit amet, consectetur adipiscing, elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua Ut enim ad minim</p>"
      },
      {
        "type": "text",
        "id": "max-width",
        "label": "Content max width (px)"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
