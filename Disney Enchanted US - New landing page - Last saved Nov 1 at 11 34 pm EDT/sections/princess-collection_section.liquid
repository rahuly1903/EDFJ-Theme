<div class="page-width">
  {% if section.settings.title != blank %}
  <div class="section-header text-center">
    <h2>{{ section.settings.title | escape }}</h2>
    {% if section.settings.category_title != blank %}
    <a href="{{ section.settings.category_url }}">
      <svg xmlns="http://www.w3.org/2000/svg" width="378" height="40" viewBox="0 0 378 40">
        <g id="Shop_all_belle_styles" data-name="{{ section.settings.category_title }}" transform="translate(-451 -1744)">
          <g id="Group_127714" data-name="Group 127714" transform="translate(0 260.5)">
            <text id="Shop_all_belle_styles-2" data-name="{{ section.settings.category_title }}" transform="translate(640 1507.5)" fill="#bc913f" font-size="14" font-family="SourceSansPro-Semibold, Source Sans Pro" font-weight="600" letter-spacing="0.15em"><tspan x="-94" y="0">{{ section.settings.category_title }}</tspan></text>
          </g>
          <g id="Button-01" transform="translate(447.808 1736.4)">
            <path id="Path_242310" data-name="Path 242310" d="M7.192,31.8a4.14,4.14,0,0,1,4.2-4.1h-.1a4.033,4.033,0,0,1-4-4.1h0a3.95,3.95,0,0,1-3.9,4.1h-.2a4.034,4.034,0,0,1,4,4.1Z" fill="#bc913f"/>
            <path id="Path_242313" data-name="Path 242313" d="M376.992,31.8a4.118,4.118,0,0,1,4.1-4.1h-.1a4.033,4.033,0,0,1-4-4.1h0a3.95,3.95,0,0,1-3.9,4.1h-.2a4.054,4.054,0,0,1,4.1,4.1Z" transform="translate(0.1)" fill="#bc913f"/>
            <path id="Path_242311" data-name="Path 242311" d="M7.992,8.8h368.4l.6,14.4.8-15.6H6.592l.7,15.6Z" fill="#bc913f"/>
            <path id="Path_242312" data-name="Path 242312" d="M376.192,46.4H8.092l-.8-14.3-.7,15.5h371.3l-.8-15.6Z" fill="#bc913f"/>
          </g>
        </g>
      </svg>      
    </a>
    {% endif %}
  </div>
  {% endif %}
  
  {% case section.settings.grid %}
  {% when 2 %}
  {%- assign grid_item_width = 'medium-up--one-half' -%}
  {% when 3 %}
  {%- assign grid_item_width = 'small--one-whole medium-up--one-third' -%}
  {% when 4 %}
  {%- assign grid_item_width = 'small--one-whole medium-up--one-quarter' -%}
  {% when 5 %}
  {%- assign grid_item_width = 'small--one-whole medium-up--one-fifth' -%}
  {% endcase %}
  
  <div class="collection-grid">
    <ul class="grid grid--uniform">
      {% for block in section.blocks limit: section.blocks.size %}
      <li class="grid__item {{ grid_item_width }}" {{ block.shopify_attributes }}>
        {%- assign collection = collections[block.settings.collection] -%}
        {% if collection.image %}
        
        {%- assign collection_image = collection.image -%}
        {% elsif collection.products.first and collection.products.first.images != empty %}
        
        {%- assign collection_image_custom = block.settings.collection_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
        {%- assign collection_image = collection.products.first.featured_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
        {% else %}
        {% assign collection_image = blank %}
        {% endif %}        
        <div class="collection__item">
          <a href="{% if collection.products == empty %}#{% else %}{{ collection.url }}{% endif %}" class="collection_item_link">
            {% if block.settings.collection_image != blank %}
            <div class="custom__item-inner--image" style="padding-top:{{ 1 | divided_by: block.settings.collection_image.aspect_ratio | times: 100}}%;">
              <img class="lazyload custom__image" data-src="{{ collection_image_custom }}" data-widths="[180, 360, 540]"
              data-aspectratio="{{ block.settings.collection_image.aspect_ratio }}" 
              data-sizes="auto" alt="{{ collection.title }}">
            </div>
            {% else %}
            {% unless collection_image == blank %}
            <div class="custom__item-inner--image" style="padding-top:{{ 1 | divided_by: collection.products.first.featured_image.aspect_ratio | times: 100}}%;">
              <img class="lazyload custom__image" data-src="{{ collection_image }}" data-widths="[180, 360, 540]"
              data-aspectratio="{{ collection.products.first.featured_image.aspect_ratio }}" 
              data-sizes="auto" alt="{{ collection.title }}">
            </div>
            {% endunless %}  
            {% endif %}        
            <div class="collection-item_title">
              <div class="h3">
                {% if block.settings.collection__title != blank %}
                {{ block.settings.collection__title }}
                <svg xmlns="http://www.w3.org/2000/svg" width="5.576" height="10.94" viewBox="0 0 5.576 10.94">
                  <path id="Right_arrow" data-name="Right arrow" d="M.342,10.94A.342.342,0,0,1,.1,10.357L4.826,5.631a.229.229,0,0,0,0-.323L.1.584A.342.342,0,0,1,.584.1L5.309,4.826a.911.911,0,0,1,0,1.289L.584,10.84a.341.341,0,0,1-.242.1" fill="#12204a"/>
                </svg>                
                {% else %}
                {{ collection.title }}
                {% endif %}
              </div>
            </div>
          </a>
        </div>
        
      </li>
      {% endfor %}
    </ul>
  </div>
  
  {% if section.blocks.size == 0 %}
  {% include 'no-blocks' %}
  {% endif %}
</div>

