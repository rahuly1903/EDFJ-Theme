<!-- custom-home-banner.liquid -->
<section data-section-type="banner__slideshow" data-section-id="{{ section.id }}">
  <div class="banner__container">
    <div class="banner">
      <div class="banner__slider">
        {% for block in section.blocks %}
        {% if block.type == 'home-banner' %}
        
        {% assign banner = block.settings.banner-img %}
        {% assign banner_mob = block.settings.banner-img-mob %}
        {% assign content-first-img = block.settings.content-first-img %}
        {% assign princess-name = block.settings.princess-name %}
        {% assign content-paragraph = block.settings.content-paragraph %}
        {% assign content-button = block.settings.content-button %}
        {% assign content-button-url = block.settings.content-button-url %}
        {% assign inspired-by = block.settings.inspired-by %}
        {% assign princess-emoticon2 = block.settings.content-emoticon %}
        
        <div id="banner-slide-{{ forloop.index }}" class="banner__slider--item lazyload" >
          <div class="banner__slider--content" id="slide-{{ forloop.index }}">
            {% if content-first-img != nil %}
            <img class="content__image lazyload" width="{{ content-first-img.width }}" height="{{ content-first-img.height }}" data-src="{{ content-first-img | img_url: '350x' }}" alt="Slider Content"
            data-sizes="auto"
            data-image />
            {% endif %}
            {% if princess-name != blank %}
            <h1 class="{{ princess-name | handleize }}">{{ princess-name }}</h1>
            {% endif %}
            {% if content-paragraph != blank %}
            <p>{{ content-paragraph }}</p>
            {% endif %}
            {% if content-button != blank %}
            <a href="{% if content-button-url != blank %}{{ content-button-url }}/{% endif %}"
            class="btn">
            {{ content-button }}
          </a>
          {% endif %}
        </div>
      </div>
      
      {% endif %}
      {% endfor %}
    </div>      
  </div>
  <div class="thumbnail">
    <div class="thumbnail__slider">
      {% for block in section.blocks %}      
      {% if block.type == 'banner-thumb' %}
      {% assign thumb = block.settings.banner-thumb | img_url: '1x1' | replace: '_1x1.', '_{width}x.' %}
      {% assign emoticon = block.settings.thumb-emoticon  %}
      <div class="thumbnail__slider--item">
        <img class="thumb__pic lazyload" alt="thumbnail image" data-src="{{ thumb }}"
        data-widths="[90, 110]"
        data-sizes="auto"
        data-image />
        {% if emoticon != blank %}
        <img class="emoticon lazyload" width="36" height="36" alt="emoticon" data-src="{{ emoticon | img_url: '36x36' }}" 
        data-widths="[36, 50]"
        data-sizes="auto"
        data-image />
        {% endif %}
      </div>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</div>
</section>

<style>
  {% for block in section.blocks %}
  {% if block.type == 'home-banner' %}
  
  {% if block.settings.banner-img != blank %}
  #banner-slide-{{ forloop.index }}{
    background-image: url("{{ block.settings.banner-img | img_url: 'master' }}");
  }
  {% endif %}
  
  {% assign inspired-by = block.settings.inspired-by %}
  {% assign princess-emoticon2 = block.settings.content-emoticon %}
  
  {% if inspired-by != blank %}
  #slide-{{ forloop.index }} h1:before {
    content: '{{ inspired-by }}';
  }
  {% endif %}
  
  
  {% if princess-emoticon2 != nil %}
  #slide-{{ forloop.index }} h1:after {
    background-image: url("{{ princess-emoticon2 | img_url: 'master' }}");
  }
  {% endif %}
  
  {% endif %}
  {% endfor %}
  #slide-2 .btn{
    font-family: "Work Sans",sans-serif;
    background-color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    line-height: 14px;
    letter-spacing: 1.4px;
    color: #000000;
    text-transform: uppercase;
    padding: 6px 12px;
    margin-left: 90px;
  }
  #slide-3 .the-collectors-edition{
    font-family: "NewYork-Regular";
    font-size: 2.4em;
    letter-spacing: 7.32px;
    color: rgba(237, 204, 126, 0.9);
    text-shadow: 0px 3px 7px rgb(0, 0, 0);
    text-transform: uppercase;
    width: 100%;
    margin-bottom: 15px;
  }
  #slide-3 .btn{
    background-color: transparent;
    border: 1px solid #ECC77A;
    font-size: 16px;
    font-weight: 500;
    line-height: 19px;
    letter-spacing: 1.6px;
    color: #ECC77A;
    text-transform: uppercase;
  }
  #slide-3 h1:before {
    left: 0.1em;
    top: -1.5em;
    width: 100%;
    font-family: "Work Sans",sans-serif;
    font-size: 36%;
    letter-spacing: 2.64px;
    color: rgba(237, 204, 126, 0.9);
    text-shadow: 0px 3px 7px rgb(0, 0, 0);
  }
  #slide-4 h1:before {
    right: 0;
    top: .5em;
  }
  #slide-5 h1:before {
    right: 0;
    top: 1em;
  }
  #slide-6 h1:before {
    right: -20px;
  }
  #slide-7 h1:before {
    right: -1em;
    top: 1em;
  }
  #slide-8 h1:before {
    right: 0;
    top: 1em;
  }
  #slide-9 h1:before {
    top: 0;
    right: -1.5em;
  }
  #slide-10 h1:before {
    right: -3.5em;
    top: 0;
  }
  #slide-11 h1:before {
    right: -33%;
    top: .5em;
  }
  #slide-12 h1:before {
    right: 8.5em;
    top: .5em;
  }
  #slide-13 h1:before {
    right: -26px;
    top: 0;
  }
  
  #slide-4 h1:after {
    width: 20%;
    right: -25%;
  }
  #slide-5 h1:after {
    width: 10%;
    right: -12%;
  }
  #slide-6 h1:after {
    width: 36%;
    right: -40%;
  }
  #slide-7 h1:after {
    width: 32%;
    right: -40%;
  }
  #slide-8 h1:after {
    width: 40%;
    right: -40%;
  }
  #slide-9 h1:after {
    width: 30%;
    background-position: center top;
    right: -40%;
  }
  #slide-10 h1:after {
    width: 34%;
    right: -46%;
  }
  #slide-11 h1:after {
    width: 34%;
    right: -46%;
  }
  #slide-12 h1:after {
    width: 12%;
    right: -18%;
  }
  #slide-13 h1:after {
    width: 40%;
    right: -45%;
  }
  @media(min-width:768px){
    #slide-1{
      bottom: 314px;
    }
    #slide-1.banner__slider--content p{
      padding-left: 52px;
      margin-top: 20px;
    }
    #slide-2{
      bottom: 284px;
    }
    #slide-3{
      width: 60%;
      bottom: 310px;
      left: 30%;
      text-align: center;
    }
  }
  @media (min-width:768px) and (max-width:1024px){
    #banner-slide-3{
      background-position: right 0px;
    }
    #slide-3{
      bottom: 240px;
      left: 24%;
    }
    #slide-3 .the-collectors-edition {
      font-size: 1.8em;
      letter-spacing: 4.32px;
    }
    #slide-3 h1:before {
      left: 5em;
      top: -2.5em;
      font-size: 44%;
      text-shadow: 1px 3px 4px rgb(0, 0, 0);
      width: 73%;
    }
  }
  @media (max-width: 750px) {
    #slide-1.banner__slider--content img{
      width: 70%;
    }
    #slide-1.banner__slider--content p{
      margin-top: 20px;
    }
    #slide-2 img{
      position: relative;
      top: -128px;
      left: -100px;
      width: 180px;
    }
    #slide-2 .btn{
      margin-left: 0;
      margin-bottom: 30px;
    }
    #banner-slide-3{
      background-position: 98% -85px;
      background-size: 220%;
    }
    #slide-3 .the-collectors-edition {
      font-size: 1.8em;
      letter-spacing: 4.32px;
    }
    #slide-3 h1:before {
      left: 0em;
      top: -2.5em;
      font-size: 44%;
      text-shadow: 1px 3px 4px rgb(0, 0, 0);
    }
    #slide-3 .btn {
      font-size: 14px;
    }
    #slide-3 h1 {
      -webkit-transform: translateX(0%);
      -ms-transform: translateX(0%);
      transform: translateX(0%);
    }
    #slide-4 h1 {
      -webkit-transform: translateX(-20%);
      -ms-transform: translateX(-20%);
      transform: translateX(-20%);
    }
    #slide-5 h1 {
      -webkit-transform: translateX(-5%);
      -ms-transform: translateX(-5%);
      transform: translateX(-5%);
    }
    #slide-6 h1 {
      -webkit-transform: translateX(-15%);
      -ms-transform: translateX(-15%);
      transform: translateX(-15%);
    }
    #slide-7 h1 {
      -webkit-transform: translateX(-20%);
      -ms-transform: translateX(-20%);
      transform: translateX(-20%);
    }
    #slide-8 h1 {
      -webkit-transform: translateX(-15%);
      -ms-transform: translateX(-15%);
      transform: translateX(-15%);
    }
    #slide-9 h1 {
      -webkit-transform: translateX(-15%);
      -ms-transform: translateX(-15%);
      transform: translateX(-15%);
    }
    #slide-10 h1 {
      -webkit-transform: translateX(-25%);
      -ms-transform: translateX(-25%);
      transform: translateX(-25%);
    }
    #slide-11 h1 {
      -webkit-transform: translateX(-25%);
      -ms-transform: translateX(-25%);
      transform: translateX(-25%);
    }
    #slide-12 h1 {
      -webkit-transform: translateX(-10%);
      -ms-transform: translateX(-10%);
      transform: translateX(-10%);
    }
    #slide-13 h1 {
      -webkit-transform: translateX(-10%);
      -ms-transform: translateX(-10%);
      transform: translateX(-10%);
    }
    {% for block in section.blocks %}
    {% if block.type == 'home-banner' and block.settings.banner-img-mob != blank %}
    #banner-slide-{{ forloop.index }}{
      background-image: url("{{ block.settings.banner-img-mob | img_url: 'master' }}");
      background-position: 0 -120px;
      background-size: cover;
    }
    {% endif %}
    {% endfor %}
  }
</style>

{% schema %}
{
  "name": "Home Banner",
  "blocks": [
  {
    "type": "home-banner",
    "name": "Slider Image (Main)",
    "settings": [
    {
      "type": "image_picker",
      "id": "banner-img",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "banner-img-mob",
      "label": "Mobile Image"
    },
    {
      "type": "header",
      "content": "Slider Content"
    },
    {
      "type": "image_picker",
      "id": "content-first-img",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "inspired-by",
      "label": "Inspired By Text",
      "default": "Inspired By"
    },
    {
      "type": "text",
      "id": "princess-name",
      "label": "Princess Name"
    },
    {
      "type": "image_picker",
      "id": "content-emoticon",
      "label": "Princess Icon Image"
    },
    {
      "type": "textarea",
      "id": "content-paragraph",
      "label": "Paragraph",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    },
    {
      "type": "text",
      "id": "content-button",
      "label": "Button",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "content-button-url",
      "label": "Button Link"
    }
    ]
  },
  {
    "type": "banner-thumb",
    "name": "Slider Image (Thumbnail)",
    "settings": [
    {
      "type": "image_picker",
      "id": "banner-thumb",
      "label": "Image"
    },
    {
      "type": "image_picker",
      "id": "thumb-emoticon",
      "label": "Emoticon image"
    }
    ]
  }
  ],
  "presets": [
  {
    "category": "Banner Slider",
    "name": "Home Banner",
    "settings": {}
  }
  ]
}
{% endschema %}