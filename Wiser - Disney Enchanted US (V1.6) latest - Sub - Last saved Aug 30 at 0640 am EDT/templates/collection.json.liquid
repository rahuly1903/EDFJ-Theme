{% layout none %}
{% paginate collection.products by 100 %}
[
  {% for product in collection.products %}
	  {% assign tags = product.tags | join:"," %}
      {% if product.available == false and tags contains 'Vault-' %}
		
	  {% else %}
      {{ product | json }}{% if forloop.last == false %},{% endif %}
      {% endif %}

  {% endfor %}
]
{% endpaginate %}