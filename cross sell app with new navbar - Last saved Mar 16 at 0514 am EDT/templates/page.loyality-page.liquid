<div class="header">
  <div class="grid">
    <div class="grid__item medium-up--five-sixths medium-up--push-one-twelfth">
      <div class="section-header text-center">
        <h1>Enchanted Disney Fine Jewelry<br/>Rewards Program</h1>
        <div class="rte">
          <div id="stamped-rewards-widget" data-widget-type="rewards-summary" data-label-signup="Sign Up Today"></div>
        </div>
      </div>
      {% comment %}
      <div class="header-banner">
        <img class="grid-view-item__image lazyload first-image float-img" alt="Ring Jewelry" data-src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/Jewelry_1.png?v=1608272007"
        data-widths="[180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]" data-sizes="auto" data-image>
      </div>
      {% endcomment %}
    </div>
  </div>
</div>
<div class="page-width">
  <div class="grid">
    <div class="grid__item medium-up--five-sixths medium-up--push-one-twelfth">
      <div class="rte">
        <div id="stamped-rewards-widget" data-widget-type="rewards-how-it-works" data-label-title="How it Works" data-label-step-title-one="Earn" data-label-step-description-one="Earn Sparkles every time you shop, review or refer your friends" data-label-step-title-two="Redeem" data-label-step-description-two="Redeem Sparkles for discount vouchers or pay using Sparkles"></div>
        {% comment %}<div id="stamped-rewards-widget" data-widget-type="rewards-earnings" data-label-title="Ways to Earn Sparkles"></div>{% endcomment %}
        <div id="ways-to-earn-sparkles" class="rewards-earning-section">
          <div class="stamped-rewards-widget-campaigns-earnings">
            <h1 class="stamped-rewards-widget-heading-main">Ways to Earn Sparkles</h1>
            <div class="stamped-rewards-widget-description">As a prestigious member of the Enchanted Disney Rewards Program, earn Sparkle points every time you purchase and redeem towards exclusive benefits</div>
            <ul class="stamped-rewards-earnings" >
              <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5786">
                <div class="stamped-rewards-widget-campaign-image">
                  <i class="fal fa-user-plus"></i>
                </div>
                <div class="stamped-rewards-widget-campaign-title">Signup Bonus</div>
                <div class="stamped-rewards-widget-campaign-value">200 Sparkles</div>
                <div class="stamped-rewards-widget-campaign-value second_text">Sign up today to get complimentary 200 Sparkle points</div>
              </li>
              <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5787">
                <div class="stamped-rewards-widget-campaign-image">
                  <i class="fal fa-birthday-cake"></i>
                </div>
                <div class="stamped-rewards-widget-campaign-title">Celebrate your birthday</div>
                <div class="stamped-rewards-widget-campaign-value">200 Sparkles</div>
                <div class="stamped-rewards-widget-campaign-value second_text">We have a birthday gift for you! We will gift you 200 Sparkle points on your birthday</div>
              </li>
              <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5781">
                <div class="stamped-rewards-widget-campaign-image">
                  <i class="fal fa-bags-shopping"></i>
                </div>
                <div class="stamped-rewards-widget-campaign-title">Make a purchase</div>
                <div class="stamped-rewards-widget-campaign-value">Earn Sparkles for every purchase</div>
                <div class="stamped-rewards-widget-campaign-value second_text"></div>
              </li>
            </ul>
          </div>
        </div>
        {% comment %}<div id="stamped-rewards-widget" data-widget-type="rewards-earnings" data-label-title="Tiers"></div>{% endcomment %}
        <div id="tiers" class="rewards-earning-section">
          <div class="stamped-rewards-widget-campaigns-earnings">
            <h1 class="stamped-rewards-widget-heading-main">Tiers</h1>
            <div class="stamped-rewards-widget-description">Shop more, Earn more sparkles</div>
            <ul class="stamped-rewards-earnings" >
              <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5782">
                <div class="stamped-rewards-widget-campaign-image">
                  <i class="fal fa-user-plus"></i>
                </div>
                <div class="stamped-rewards-widget-campaign-title">Silver</div>
                <div class="stamped-rewards-widget-campaign-value"><2000 Sparkles</div>
                  <div class="stamped-rewards-widget-campaign-value">1 Sparkle for every $1 Spent</div>
                </li>
                <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5783">
                  <div class="stamped-rewards-widget-campaign-image">
                    <i class="fal fa-user-plus"></i>
                  </div>
                  <div class="stamped-rewards-widget-campaign-title">Gold</div>
                  <div class="stamped-rewards-widget-campaign-value">2000-7500 Sparkles</div>
                  <div class="stamped-rewards-widget-campaign-value">1.5 Sparkles for every $1 Spent</div>
                </li>
                <li class="stamped-rewards-widget-campaign stamped-rewards-widget-campaign-content" data-campaign-id="5784">
                  <div class="stamped-rewards-widget-campaign-image">
                    <i class="fal fa-user-plus"></i>
                  </div>
                  <div class="stamped-rewards-widget-campaign-title">Platinum</div>
                  <div class="stamped-rewards-widget-campaign-value">>7500 Sparkles</div>
                  <div class="stamped-rewards-widget-campaign-value">2 Sparkles for every $1 Spent</div>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <div class="rte reward-redeem">
          <div class="spending-banner">
            <img class="grid-view-item__image lazyload first-image float-img" alt="Rose Ring Jewelry" data-src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/Group_20723.png?v=1608269737"
            data-widths="[180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]" data-sizes="auto" data-image>
          </div>
          <div id="stamped-rewards-widget" data-widget-type="rewards-spendings" data-label-description="Redeeming your Sparkles is easy. &lt;br&gt; Simply exchange your Sparkles for discount coupons to spend in any order. "></div>
        </div>
        <div class="rte reward-refer">
          <div id="stamped-rewards-widget" data-widget-type="rewards-referral" data-label-description="Earn Sparkles when your friend makes their first purchase"></div>
          <div class="refrral-banner">
            <img class="grid-view-item__image lazyload first-image float-img" alt="Box Jewelry" data-src="https://cdn.shopify.com/s/files/1/0267/0523/1943/files/Group_20686.png?v=1608269825"
            data-widths="[180, 360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]" data-sizes="auto" data-image>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <style>
    :root {
      --stamped-rewards-theme-color: #11214a;
      --stamped-rewards-button-color-background: #000;
      --stamped-rewards-button-color-text: #fff;
    }
    
    .rewards-earning-section .stamped-rewards-widget-heading-main {
      font-size: 36px;
      text-align: center;
      margin-bottom: 60px;
      text-transform: initial;
      letter-spacing: 1px;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaigns-earnings {
      padding: 0px 0 40px;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaigns-earnings ul {
      padding: 0;
      display: -ms-flexbox;
      display: flex;
      -ms-flex-wrap: wrap;
      flex-wrap: wrap;
      -ms-flex-pack: center;
      justify-content: center;
      -ms-flex-align: center;
      align-items: center;
      max-width: 1400px;
      margin: 0 auto;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaigns-earnings .stamped-rewards-widget-campaign-image img {
      width: 84px;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaign-image {
      margin-bottom: 15px;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaign-image > i,
    .rewards-earning-section .stamped-rewards-widget-campaign-image > i:before {
      font-size: 46px;
      margin-bottom: 2px;
    }
    
    .rewards-earning-section .stamped-rewards-widget-campaign-title {
      margin-bottom: 5px;
      font-weight: bold;
    }
  </style>